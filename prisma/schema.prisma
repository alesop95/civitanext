// Schema iniziale di Fase 0 (fondamenta): solo le entita' indicate dal
// ROADMAP di design_handoff_civitanext/ROADMAP.md (User, Event, Thread,
// Reply, Proposal) piu' Vote, anticipata per definizione di schema perche'
// il vincolo di voto unico per utente attraversa piu' feature (sondaggi,
// forum, proposte) e cosi' si evita una migrazione di rottura quando in
// Fase 1/2 il voto verra' davvero cablato a UI e API. Nessuna feature
// utente in questa fase: solo struttura dati.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Il ruolo e' l'asse di autorizzazione (cosa un account puo' fare), indipendente dal
// tesseramento (se e' un socio verificato dell'associazione, tracciato da User.tesseraNumero).
// Un UTENTE puo' avere tesseraNumero valorizzato o nullo: essere socio non e' un ruolo.
enum Role {
  SUPERADMIN
  ADMIN
  UTENTE
}

enum ProposalStatus {
  REVISIONE
  VOTAZIONE
  APPROVATA
}

enum VoteTargetType {
  THREAD
  PROPOSAL
  POLL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // Nullable: un utente registrato solo via provider OAuth (Google) non ha mai impostato
  // una password propria.
  passwordHash  String?
  name          String
  role          Role      @default(UTENTE)
  tesseraNumero String?   @unique
  memberSince   DateTime  @default(now())
  emailVerified DateTime?
  image         String?
  // Preferenza esplicita, default false: a differenza del toggle del prototipo (solo
  // localStorage, default "acceso"), qui l'invio e' un'email vera a un indirizzo reale, quindi
  // un utente gia' esistente al momento della migrazione non riceve nulla finche' non lo attiva
  // lui stesso (nessun opt-in implicito su una feature che prima non esisteva).
  digestOptIn   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  threads       Thread[]
  replies       Reply[]
  proposals     Proposal[]
  votes         Vote[]
  accounts      Account[]
  rsvps         Rsvp[]
  quizAttempts   QuizAttempt[]
  notifications  Notification[]
  skills         Skill[]
  mentorRequests MentorRequest[]
  photoAlbumsCreated PhotoAlbum[] @relation("PhotoAlbumCreatedBy")
  photos             Photo[]     @relation("PhotoUploader")
  documentsCreated   Document[]
  pushSubscriptions  PushSubscription[]
  deletionRequests         AccountDeletionRequest[] @relation("AccountDeletionRequester")
  deletionRequestsHandled  AccountDeletionRequest[] @relation("AccountDeletionProcessedBy")
}

// Collega un utente a uno o piu' provider di autenticazione (credenziali gestite a parte via
// User.passwordHash, oppure OAuth). Richiesto da @auth/prisma-adapter; i campi che rispecchiano
// la risposta del provider OAuth (refresh_token, access_token, ecc.) mantengono i nomi esatti
// che l'adapter scrive, non la convenzione camelCase del resto dello schema.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Richiesto da @auth/prisma-adapter per la verifica email/reset password via link a scadenza.
// Nessun modello Session: la strategia di sessione e' JWT (ADR-010), quindi @auth/prisma-adapter
// non invoca mai i metodi che lo richiederebbero.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps       Rsvp[]
  photoAlbums PhotoAlbum[]
}

// Un utente non puo' iscriversi due volte allo stesso evento: vincolo di unicita' a livello di
// database (@@unique), stesso principio gia' applicato a Vote (refactor-04), non un controllo
// applicativo prima di scrivere.
model Rsvp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  category  String
  body      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  replies   Reply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reply {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Proposal {
  id          String         @id @default(cuid())
  title       String
  category    String
  description String
  authorId    String
  author      User           @relation(fields: [authorId], references: [id])
  status      ProposalStatus @default(REVISIONE)
  // Attuazione (feedback loop, Fase 2.5): nota di aggiornamento libera piu' una checklist di step
  // ordinati (ProposalStep). Riguarda le proposte APPROVATA; non e' un nuovo stato dell'enum ma un
  // sotto-tracciamento, come nel prototipo (CN_FEEDBACK: steps + note su una proposta approvata).
  implementationNote String?
  implementationSteps ProposalStep[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// Un passo di attuazione di una proposta approvata (Fase 2.5). Relazionale e non JSON, coerente
// con la scelta gia' fatta per le opzioni del quiz (ADR-011): ordine esplicito e stato done per
// singolo passo, cosi' la checklist e' interrogabile e ogni passo si spunta a se'. onDelete
// Cascade: cancellando la proposta spariscono i suoi passi.
model ProposalStep {
  id         String   @id @default(cuid())
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  label      String
  order      Int      @default(0)
  done       Boolean  @default(false)
}

// Vincolo di voto unico per utente, condiviso da piu' feature (sondaggi,
// thread, proposte). targetId non e' una foreign key vera perche' punta a
// modelli diversi a seconda di targetType (pattern polimorfico): si perde
// l'integrita' referenziale a livello di database su quel campo, un
// compromesso deliberato per evitare tre tabelle di voto quasi identiche.
model Vote {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  targetType VoteTargetType
  targetId   String
  createdAt  DateTime       @default(now())

  @@unique([userId, targetType, targetId])
}

// Modello Quiz (ADR-011). order determina sia l'ordine di visualizzazione sia lo sblocco
// progressivo: un quiz con order > 0 e' sbloccato solo se esiste un QuizAttempt per il quiz
// con order immediatamente precedente (calcolato in query, non un campo separato).
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])
  text   String
  order  Int    @default(0)

  options QuizOption[]
  answers QuizAnswer[]
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean      @default(false)

  answers QuizAnswer[]
}

// Un solo tentativo registrato per utente per quiz (@@unique), non uno storico di tentativi:
// ripetere il quiz aggiorna questa riga (e le QuizAnswer collegate) solo se il nuovo punteggio
// e' migliore del precedente (ADR-011), logica applicativa, non vincolo di schema.
model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  score     Int
  total     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers QuizAnswer[]

  @@unique([userId, quizId])
}

// Una riga per domanda per tentativo: e' quello che rende possibile il feedback "hai sbagliato
// questa domanda, la risposta giusta era questa" invece di un semplice punteggio aggregato.
model QuizAnswer {
  id         String       @id @default(cuid())
  attemptId  String
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id])
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  optionId   String
  option     QuizOption   @relation(fields: [optionId], references: [id])
  isCorrect  Boolean

  @@unique([attemptId, questionId])
}

// Notifiche in-app (Fase 3, dopo responsive/PWA). link e' un percorso opzionale (es. la proposta
// che ha generato la notifica), non una foreign key: la notifica deve restare leggibile anche se
// il contenuto collegato viene cancellato in seguito.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Notifiche push (passo dichiarato dopo le notifiche in-app di Fase 3, mai affrontato finora).
// Un abbonamento per dispositivo/browser, non per utente: lo stesso socio su telefono e desktop
// ha due righe distinte, ciascuna con l'endpoint del push service del proprio browser
// (endpoint e' univoco per costruzione: e' l'URL che il browser assegna a quella sottoscrizione).
// p256dh/auth sono le chiavi pubbliche del dispositivo richieste dal protocollo Web Push per
// cifrare il payload, non credenziali del progetto. notifyUser (src/lib/notifications.ts) invia
// un push a ogni riga di un utente quando crea una Notification in-app; una sottoscrizione che il
// push service segnala come scaduta (404/410) viene cancellata li', non qui.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Richiesta di cancellazione account (GDPR, ADR-018): il socio la invia da /profilo, un admin la
// esegue a mano da /admin/account-deletion. "Cancellazione" nell'interfaccia significa
// anonimizzazione dei dati personali (email, nome, password, tessera), non rimozione della riga
// User ne' dei contenuti: un thread o una proposta approvata restano, potendo avere risposte o
// discussioni di altri soci agganciate, ma l'autore diventa "Utente cancellato". La riga di
// questa tabella resta anche dopo l'esecuzione, come traccia scritta della richiesta e di chi
// l'ha gestita: e' proprio quella traccia, insieme alla riga User anonimizzata ma non cancellata,
// che rende la richiesta ricollegabile in futuro se servisse dimostrare la conformita'.
model AccountDeletionRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("AccountDeletionRequester", fields: [userId], references: [id])
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  processedById String?
  processedBy   User?     @relation("AccountDeletionProcessedBy", fields: [processedById], references: [id])
}

// Sondaggio rapido in home (Fase 4). Il voto riusa Vote con targetType POLL e targetId
// = PollOption.id, anticipato fin dalla Fase 0 (vedi enum VoteTargetType) e mai usato finora.
// A differenza di Proposal/Thread, qui il vincolo "un voto per sondaggio, non per opzione" non
// si esprime nello schema: Vote garantisce solo un voto per (utente, opzione), non per
// (utente, sondaggio), quindi l'azione applicativa deve controllare le altre opzioni dello
// stesso sondaggio prima di scrivere (stesso limite gia' accettato per il pattern polimorfico
// di Vote, refactor-04).
model Poll {
  id        String       @id @default(cuid())
  question  String
  createdAt DateTime     @default(now())

  options PollOption[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id])
  text   String
}

// Elenco spazi civici (Fase 4, sezione "Citta'" del ROADMAP di design). Contenuto puramente
// informativo gestito da un admin, nessun vincolo relazionale con altri modelli: stessa forma
// dei dati statici del prototipo (CN_SPACES in civitanext-data.jsx).
model CivicSpace {
  id        String   @id @default(cuid())
  name      String
  type      String
  hours     String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Distingue le voci della timeline: storia della citta' oppure tappe dell'associazione
// (nel prototipo CN_TIMELINE e' il campo kind 'citta'/'cn'). Enum e non String come
// Event.category perche' e' un insieme chiuso a due valori che pilota il rendering
// (le tappe dell'associazione sono evidenziate), non una categoria libera.
enum TimelineKind {
  CITTA
  ASSOCIAZIONE
}

// Timeline storica (Fase 4, sezione "Citta'"). when e' testo libero di proposito: le voci
// storiche del prototipo valgono "Da completare" o epoche ("Anni '50") che una DateTime non
// esprime. Proprio perche' when non e' ordinabile, l'ordine cronologico e' un campo esplicito
// (order, stesso meccanismo di Quiz.order). Il flag photo del prototipo e' omesso: le immagini
// arriveranno con la galleria (decisione storage ADR-004/005 ancora da confrontare).
model TimelineEntry {
  id        String       @id @default(cuid())
  when      String
  title     String
  text      String
  kind      TimelineKind
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

// Rassegna stampa (Fase 4, sezione "Community"). Articoli usciti su testate locali, curati a
// mano da un admin: stesso pattern informativo di CivicSpace, nessuna relazione. publishedAt
// e' una data vera, non il testo libero del prototipo (CN_PRESS), perche' l'elenco si ordina
// dal piu' recente; url opzionale perche' un articolo puo' esistere solo su carta. Il conteggio
// commenti del prototipo e' omesso di proposito: le discussioni dei soci vivono nel forum.
model PressArticle {
  id          String   @id @default(cuid())
  source      String
  title       String
  url         String?
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

// Pin sulla mappa della citta' (Fase 4, sezione "Citta'"). Punto gestito a mano da un admin,
// non agganciato a Event/Proposal: quei modelli non hanno coordinate geografiche ne' una form
// di creazione oggi, quindi collegarli avrebbe allargato lo scope di questa sola feature.
// lat/lng sono coordinate reali (gradi decimali), non le percentuali x/y del placeholder nel
// prototipo di design (CN_MAP_POINTS in civitanext-data.jsx).
model MapPoint {
  id        String   @id @default(cuid())
  title     String
  type      String
  place     String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
}

// Competenze (Fase 4, sezione "Community"): bacheca di matching tra soci. A differenza delle
// altre feature informative di Fase 4 (CivicSpace, MapPoint, TimelineEntry, PressArticle), curate
// da un admin, questa e' contenuto autoriale generato dagli utenti come i Thread del forum: la
// voce appartiene a un User (relazione reale) e la guardia e' di sola autenticazione, non di
// ruolo. name e offer sono testo libero, non una tassonomia chiusa ne' tag normalizzati: stessa
// scelta di CivicSpace.hours e opposta all'enum TimelineKind (la tensione della voce didattica
// 11), qui giustificata dal long tail delle competenze civiche e dal fatto che nessuna feature
// attuale fa matching automatico sul valore (la mentorship del prototipo e' una feature separata,
// con area e slot propri). Un socio puo' avere piu' righe (piu' competenze offerte).
model Skill {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  offer     String
  createdAt DateTime @default(now())
}

// Mentorship (Fase 4, sezione "Community"). Lista curata da un admin, non self-service: nel
// prototipo (CN_MENTORS) diventare mentor passa da un contatto offline ("scrivici dal forum o
// agli eventi"), quindi Mentor e' un modello autonomo gestito dall'admin come CivicSpace o
// PressArticle, non contenuto autoriale legato a un User come Skill. slots e' un numero
// informativo ("posti disponibili questo mese"), non un contatore che si decrementa: nel
// prototipo i posti non calano alla richiesta.
model Mentor {
  id          String   @id @default(cuid())
  name        String
  area        String
  description String
  slots       Int      @default(1)
  createdAt   DateTime @default(now())

  requests MentorRequest[]
}

// La richiesta di incontro persiste (a differenza del prototipo, dove il bottone "Chiedi un
// incontro" cambia solo stato locale): un socio loggato esprime interesse una sola volta per
// mentor (@@unique), stesso principio di unicita' gia' applicato a Rsvp e Vote. Nessun
// decremento di slots ne' flusso di accettazione: il mentor non e' un account, il coordinamento
// resta offline com'e' nel prototipo; la richiesta serve a non avere un bottone finto e a far
// vedere all'admin chi ha chiesto.
model MentorRequest {
  id        String   @id @default(cuid())
  mentorId  String
  mentor    Mentor   @relation(fields: [mentorId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([mentorId, userId])
}

// Galleria foto (Fase 4, sezione "Citta'"): prima feature del progetto con upload di file
// binari. Album e' un contenitore curato: lo apre un admin (nome + evento passato opzionale,
// come Mentor/CivicSpace), le foto le aggiungono i soci self-service (come MentorRequest/Skill).
// eventId e' opzionale perche' non ogni album corrisponde a un Event esistente in modello (es.
// un raduno informale) — stessa scelta di non forzare una FK gia' presa per MapPoint verso
// Event/Proposal. L'upload e' proxato dal server Next.js (non URL presigned dirette a R2): il
// server legge l'intero file e ne verifica i byte reali prima di scriverlo su R2, cosi' nessun
// oggetto non valido raggiunge mai il bucket (ADR-016).
model PhotoAlbum {
  id          String   @id @default(cuid())
  title       String
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
  createdById String
  createdBy   User     @relation("PhotoAlbumCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  photos Photo[]
}

// Una foto = un oggetto R2 + metadati rilevati dal server sui byte reali del file (r2Key,
// contentType, size), mai quelli dichiarati dal client: contentType e' il risultato di
// detectImageType (magic bytes), non l'estensione o il File.type del browser (falsificabili).
model Photo {
  id          String     @id @default(cuid())
  albumId     String
  album       PhotoAlbum @relation(fields: [albumId], references: [id])
  uploaderId  String
  uploader    User       @relation("PhotoUploader", fields: [uploaderId], references: [id])
  r2Key       String     @unique
  contentType String
  size        Int
  createdAt   DateTime   @default(now())
}

// Categorie chiuse del filtro a chip del prototipo (CN_DOCS in civitanext-data.jsx): enum, non
// testo libero, perche' pilota il filtro della UI come TimelineKind (voce didattica 11), non e'
// un valore descrittivo libero come CivicSpace.type.
enum DocumentCategory {
  STATUTO
  VERBALI
  BILANCI
}

// Documenti istituzionali (Fase 4, sezione "Citta'"): statuto, verbali, bilanci. A differenza
// della galleria, il prototipo non mostra alcun caricamento self-service ("caricate dai soci" e'
// testo esplicito solo per CN_GALLERY, assente per CN_DOCS: solo lettura/filtro/download):
// upload riservato all'admin, stesso principio di CivicSpace/PressArticle/MapPoint. Stesso
// meccanismo di upload proxato + validazione sui byte reali della galleria (ADR-016), qui sul
// magic number PDF (%PDF) invece che JPEG/PNG/WEBP.
model Document {
  id          String           @id @default(cuid())
  title       String
  category    DocumentCategory
  r2Key       String           @unique
  contentType String
  size        Int
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
}

// Webinar (Fase 4, sezione "Community"): registrazioni di assemblee e lezioni civiche. Solo dati
// e imbed, mai storage del video (nota di ADR-004, qui formalizzata): il prototipo (CN_WEBINARS)
// non mostra ne' upload self-service ne' sezione admin, stesso trattamento informativo di
// PressArticle/CivicSpace/MapPoint (curato da un admin, nessuna relazione con User). youtubeId e'
// solo l'id del video (11 caratteri), non l'URL intero: l'URL di embed e la thumbnail si
// compongono a runtime (src/lib/youtube.ts), stessa scelta di comporre l'URL pubblico da r2Key
// invece di salvare un URL completo. Nessun campo "views": richiederebbe la YouTube Data API,
// una seconda integrazione esterna non giustificata dal valore che aggiungerebbe oggi.
model Webinar {
  id          String   @id @default(cuid())
  title       String
  description String
  youtubeId   String
  duration    String
  recordedAt  DateTime
  createdAt   DateTime @default(now())
}
