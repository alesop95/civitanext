// Schema iniziale di Fase 0 (fondamenta): solo le entita' indicate dal
// ROADMAP di design_handoff_civitanext/ROADMAP.md (User, Event, Thread,
// Reply, Proposal) piu' Vote, anticipata per definizione di schema perche'
// il vincolo di voto unico per utente attraversa piu' feature (sondaggi,
// forum, proposte) e cosi' si evita una migrazione di rottura quando in
// Fase 1/2 il voto verra' davvero cablato a UI e API. Nessuna feature
// utente in questa fase: solo struttura dati.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Il ruolo e' l'asse di autorizzazione (cosa un account puo' fare), indipendente dal
// tesseramento (se e' un socio verificato dell'associazione, tracciato da User.tesseraNumero).
// Un UTENTE puo' avere tesseraNumero valorizzato o nullo: essere socio non e' un ruolo.
enum Role {
  SUPERADMIN
  ADMIN
  UTENTE
}

enum ProposalStatus {
  REVISIONE
  VOTAZIONE
  APPROVATA
}

enum VoteTargetType {
  THREAD
  PROPOSAL
  POLL
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // Nullable: un utente registrato solo via provider OAuth (Google) non ha mai impostato
  // una password propria.
  passwordHash  String?
  name          String
  role          Role      @default(UTENTE)
  tesseraNumero String?   @unique
  memberSince   DateTime  @default(now())
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  threads       Thread[]
  replies       Reply[]
  proposals     Proposal[]
  votes         Vote[]
  accounts      Account[]
  rsvps         Rsvp[]
  quizAttempts  QuizAttempt[]
  notifications Notification[]
}

// Collega un utente a uno o piu' provider di autenticazione (credenziali gestite a parte via
// User.passwordHash, oppure OAuth). Richiesto da @auth/prisma-adapter; i campi che rispecchiano
// la risposta del provider OAuth (refresh_token, access_token, ecc.) mantengono i nomi esatti
// che l'adapter scrive, non la convenzione camelCase del resto dello schema.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Richiesto da @auth/prisma-adapter per la verifica email/reset password via link a scadenza.
// Nessun modello Session: la strategia di sessione e' JWT (ADR-010), quindi @auth/prisma-adapter
// non invoca mai i metodi che lo richiederebbero.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rsvps Rsvp[]
}

// Un utente non puo' iscriversi due volte allo stesso evento: vincolo di unicita' a livello di
// database (@@unique), stesso principio gia' applicato a Vote (refactor-04), non un controllo
// applicativo prima di scrivere.
model Rsvp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  category  String
  body      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  replies   Reply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reply {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())
}

model Proposal {
  id          String         @id @default(cuid())
  title       String
  category    String
  description String
  authorId    String
  author      User           @relation(fields: [authorId], references: [id])
  status      ProposalStatus @default(REVISIONE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// Vincolo di voto unico per utente, condiviso da piu' feature (sondaggi,
// thread, proposte). targetId non e' una foreign key vera perche' punta a
// modelli diversi a seconda di targetType (pattern polimorfico): si perde
// l'integrita' referenziale a livello di database su quel campo, un
// compromesso deliberato per evitare tre tabelle di voto quasi identiche.
model Vote {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  targetType VoteTargetType
  targetId   String
  createdAt  DateTime       @default(now())

  @@unique([userId, targetType, targetId])
}

// Modello Quiz (ADR-011). order determina sia l'ordine di visualizzazione sia lo sblocco
// progressivo: un quiz con order > 0 e' sbloccato solo se esiste un QuizAttempt per il quiz
// con order immediatamente precedente (calcolato in query, non un campo separato).
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id])
  text   String
  order  Int    @default(0)

  options QuizOption[]
  answers QuizAnswer[]
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  text       String
  isCorrect  Boolean      @default(false)

  answers QuizAnswer[]
}

// Un solo tentativo registrato per utente per quiz (@@unique), non uno storico di tentativi:
// ripetere il quiz aggiorna questa riga (e le QuizAnswer collegate) solo se il nuovo punteggio
// e' migliore del precedente (ADR-011), logica applicativa, non vincolo di schema.
model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  score     Int
  total     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers QuizAnswer[]

  @@unique([userId, quizId])
}

// Una riga per domanda per tentativo: e' quello che rende possibile il feedback "hai sbagliato
// questa domanda, la risposta giusta era questa" invece di un semplice punteggio aggregato.
model QuizAnswer {
  id         String       @id @default(cuid())
  attemptId  String
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id])
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  optionId   String
  option     QuizOption   @relation(fields: [optionId], references: [id])
  isCorrect  Boolean

  @@unique([attemptId, questionId])
}

// Notifiche in-app (Fase 3, dopo responsive/PWA). link e' un percorso opzionale (es. la proposta
// che ha generato la notifica), non una foreign key: la notifica deve restare leggibile anche se
// il contenuto collegato viene cancellato in seguito.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Sondaggio rapido in home (Fase 4). Il voto riusa Vote con targetType POLL e targetId
// = PollOption.id, anticipato fin dalla Fase 0 (vedi enum VoteTargetType) e mai usato finora.
// A differenza di Proposal/Thread, qui il vincolo "un voto per sondaggio, non per opzione" non
// si esprime nello schema: Vote garantisce solo un voto per (utente, opzione), non per
// (utente, sondaggio), quindi l'azione applicativa deve controllare le altre opzioni dello
// stesso sondaggio prima di scrivere (stesso limite gia' accettato per il pattern polimorfico
// di Vote, refactor-04).
model Poll {
  id        String       @id @default(cuid())
  question  String
  createdAt DateTime     @default(now())

  options PollOption[]
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id])
  text   String
}

// Elenco spazi civici (Fase 4, sezione "Citta'" del ROADMAP di design). Contenuto puramente
// informativo gestito da un admin, nessun vincolo relazionale con altri modelli: stessa forma
// dei dati statici del prototipo (CN_SPACES in civitanext-data.jsx).
model CivicSpace {
  id        String   @id @default(cuid())
  name      String
  type      String
  hours     String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Distingue le voci della timeline: storia della citta' oppure tappe dell'associazione
// (nel prototipo CN_TIMELINE e' il campo kind 'citta'/'cn'). Enum e non String come
// Event.category perche' e' un insieme chiuso a due valori che pilota il rendering
// (le tappe dell'associazione sono evidenziate), non una categoria libera.
enum TimelineKind {
  CITTA
  ASSOCIAZIONE
}

// Timeline storica (Fase 4, sezione "Citta'"). when e' testo libero di proposito: le voci
// storiche del prototipo valgono "Da completare" o epoche ("Anni '50") che una DateTime non
// esprime. Proprio perche' when non e' ordinabile, l'ordine cronologico e' un campo esplicito
// (order, stesso meccanismo di Quiz.order). Il flag photo del prototipo e' omesso: le immagini
// arriveranno con la galleria (decisione storage ADR-004/005 ancora da confrontare).
model TimelineEntry {
  id        String       @id @default(cuid())
  when      String
  title     String
  text      String
  kind      TimelineKind
  order     Int          @default(0)
  createdAt DateTime     @default(now())
}

// Rassegna stampa (Fase 4, sezione "Community"). Articoli usciti su testate locali, curati a
// mano da un admin: stesso pattern informativo di CivicSpace, nessuna relazione. publishedAt
// e' una data vera, non il testo libero del prototipo (CN_PRESS), perche' l'elenco si ordina
// dal piu' recente; url opzionale perche' un articolo puo' esistere solo su carta. Il conteggio
// commenti del prototipo e' omesso di proposito: le discussioni dei soci vivono nel forum.
model PressArticle {
  id          String   @id @default(cuid())
  source      String
  title       String
  url         String?
  publishedAt DateTime
  createdAt   DateTime @default(now())
}

// Pin sulla mappa della citta' (Fase 4, sezione "Citta'"). Punto gestito a mano da un admin,
// non agganciato a Event/Proposal: quei modelli non hanno coordinate geografiche ne' una form
// di creazione oggi, quindi collegarli avrebbe allargato lo scope di questa sola feature.
// lat/lng sono coordinate reali (gradi decimali), non le percentuali x/y del placeholder nel
// prototipo di design (CN_MAP_POINTS in civitanext-data.jsx).
model MapPoint {
  id        String   @id @default(cuid())
  title     String
  type      String
  place     String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
}
