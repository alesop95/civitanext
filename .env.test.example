# Copiare in .env.test (gia' ignorato da git, stesso pattern di .env) per far girare in locale
# i test Vitest che toccano un Postgres reale. Punta al container di docker-compose.test.yml,
# mai al Neon di sviluppo in .env: `npm run test:db:up` lo avvia sulla porta 5433.
DATABASE_URL="postgresql://civitanext_test:civitanext_test@localhost:5433/civitanext_test"
