# Modello delle variabili d'ambiente di webapp/. Nessun valore reale va scritto qui:
# questo file e' tracciato da git, .env e .dev.vars restano locali e ignorati.

# Connessione Postgres (Neon in produzione, locale via `npx prisma dev` in sviluppo)
DATABASE_URL=

# NextAuth (Fase 1): chiave di firma sessione, distinta per ambiente test/produzione
AUTH_SECRET=
